{
  "name": "thaikolja/ai-image-renamer",
  "description": "WordPress plugin that automatically renames uploaded images using Groq's Vision API for SEO-friendly filenames.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Kolja",
      "email": "kolja@example.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "twig/twig": "^3.0",
    "defuse/php-encryption": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "AIR\\": "includes/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
