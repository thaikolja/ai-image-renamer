{# Header Component - Plugin Branding #}
{% set link = '?page=' ~ page_slug %}
<div class="air-header">
    <div class="air-header-left">
        <a href="{{ link }}">
            <div class="air-header-logo">
                <span class="dashicons dashicons-format-image"></span>
            </div>
        </a>
        <div class="air-header-title">
            <a href="{{ link }}">
                <h1>{{ page_title }}</h1>
            </a>
        </div>
    </div>
    <div class="air-header-right">
        <span class="air-header-version">
            v{{ version }}
        </span>
    </div>
</div>
