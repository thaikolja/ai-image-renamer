{# Advanced Settings Template #}
<div class="air-card">
    <div class="air-card-header">
        <h2>
            <span class="dashicons dashicons-admin-tools"></span>
            {{ __('Advanced Settings', 'ai-image-renamer') }}
            <a href="{{ doc_url('usage/settings#advanced-settings') }}" target="_blank" rel="noopener noreferrer" class="air-doc-badge"> <span class="dashicons dashicons-book"></span> <span>{{ __('Documentation', 'ai-image-renamer') }}</span> </a>
        </h2>
        <p class="air-card-description">
            {{ __('Fine-tune AI behavior and output.', 'ai-image-renamer') }}
        </p>
    </div>
    <div class="air-card-body">
        {# Max Keywords Setting #}
        <div class="air-setting-row">
            <div class="air-setting-label">
                <label for="air_max_keywords">{{ __('Max Keywords', 'ai-image-renamer') }}</label>
                <p class="air-setting-description">
                    {{ __('Maximum number of keywords to include in the filename (1-10). Recommended: 5', 'ai-image-renamer') }}
                </p>
            </div>
            <div class="air-setting-control">
                <input type="number" id="air_max_keywords" name="{{ option_name }}[max_keywords]" value="{{ max_keywords }}" min="1" max="10" class="small-text air-number-input">
            </div>
        </div>
    </div>
</div>

{# Diagnostics Card #}
<div class="air-card air-diagnostics-card">
    <div class="air-card-header">
        <h2>
            <span class="dashicons dashicons-info"></span>
            {{ __('System Diagnostics', 'ai-image-renamer') }}
        </h2>
        <p class="air-card-description">{{ __('Server information and system requirements.', 'ai-image-renamer') }}</p>
    </div>
    <div class="air-card-body">
        <table class="widefat air-diagnostics-table">
            <tbody>
            {% for key, data in diagnostics %}
                <tr>
                    <td>
                        <strong>{{ data.label }}</strong> <span>{{ data.desc }}</span>
                    </td>
                    <td>
                        <code>{{ data.value }}</code>
                        {% if data.ok %}
                            <span class="dashicons dashicons-yes"></span>
                        {% else %}
                            <span class="dashicons dashicons-warning"></span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
