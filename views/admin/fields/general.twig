{# General Settings Template #}
{% include 'admin/components/intro.twig' %}
<div class="air-card">
    <div class="air-card-header">
        <h2>
            <span class="dashicons dashicons-admin-settings"></span>
            {{ __('General Settings', 'ai-image-renamer') }}
            <a href="{{ doc_url('usage/settings') }}" target="_blank" rel="noopener noreferrer" class="air-doc-badge">
                <span class="dashicons dashicons-book"></span>
                <span>{{ __('Documentation', 'ai-image-renamer') }}</span> </a>
        </h2>
        <p class="air-card-description">{{ __('Choose what should happen when new images are uploaded.', 'ai-image-renamer') }}</p>
    </div>
    <div class="air-card-body">
        <div class="air-setting-row">
            <div class="air-setting-label">
                <label for="air_enabled">{{ __('Enable Auto-Rename', 'ai-image-renamer') }}</label>
                <p class="air-setting-description">{{ __('Automatically rename supported image uploads while WordPress processes them.', 'ai-image-renamer') }}</p>
            </div>
            <div class="air-setting-control">
                <label class="air-toggle">
                    <input type="checkbox" id="air_enabled" name="{{ option_name }}[enabled]" value="1" {{ enabled ? 'checked' : '' }}>
                    <span class="air-toggle-slider"></span>
                </label>
            </div>
        </div>
        <div class="air-setting-row">
            <div class="air-setting-label">
                <label for="air_set_alt_text">{{ __('Populate Alt Text', 'ai-image-renamer') }}</label>
                <p class="air-setting-description">{{ __('Save a cleaned version of the generated description as the attachment alt text.', 'ai-image-renamer') }}</p>
            </div>
            <div class="air-setting-control">
                <label class="air-toggle">
                    <input type="checkbox" id="air_set_alt_text" name="{{ option_name }}[set_alt_text]" value="1" {{ set_alt_text ? 'checked' : '' }}>
                    <span class="air-toggle-slider"></span>
                </label>
            </div>
        </div>
    </div>
</div>
