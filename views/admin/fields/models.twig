{# Models Panel Template #}
<div class="air-card">
    <div class="air-card-header">
        <h2>
            <span class="dashicons dashicons-grid-view"></span>
            {{ __('AI Models', 'ai-image-renamer') }}
            <a href="{{ doc_url('usage/settings#ai-model') }}" target="_blank" rel="noopener noreferrer" class="air-doc-badge">
                <span class="dashicons dashicons-book"></span>
                <span>{{ __('Documentation', 'ai-image-renamer') }}</span> </a>
        </h2>
        <p class="air-card-description">{{ __('Choose which Groq vision model should analyze new uploads.', 'ai-image-renamer') }}</p>
    </div>
    <div class="air-card-body">
        <div class="air-setting-row air-setting-row--stacked">
            <div class="air-setting-control">
                <div class="air-model-cards">
                    {% include 'admin/fields/model.twig' with {
                        models: models,
                        current: current,
                        option_name: option_name,
                        asset_url: asset_url
                    } %}
                </div>
                <p class="deprecation-notice">
                    {{ __('Llama 4 Maverick was deprecated by Groq on March 9, 2026.', 'ai-image-renamer') }}
                    <a href="https://console.groq.com/docs/deprecations#march-9-2026-metallamallama4maverick17b128einstruct" target="_blank" rel="noopener noreferrer">{{ __('Read the deprecation notice', 'ai-image-renamer') }}</a>
                </p>
            </div>
        </div>
    </div>
</div>
