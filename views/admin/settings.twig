{# Admin Settings Page Template - Modern Tab Layout #}
<div
	class="wrap air-settings-wrap">
	{# Header #}
	{% include 'admin/components/header.twig' %}

	<div
		class="air-settings-container">
		{# Tab Navigation (Sidebar) #}
		<aside class="air-settings-nav">
			{% include 'admin/components/tabs.twig' %}
		</aside>

		{# Main Content Area #}
		<main class="air-settings-content">
			<form method="post" action="options.php" id="air-settings-form">
				{{ settings_fields(option_group)|raw }}

				{# API Configuration Panel #}
				<div id="air-panel-api" class="air-panel active" role="tabpanel" aria-labelledby="air-tab-api">
					<div class="air-card">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-admin-network"></span>
								{{ __('API Configuration', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Connect to the Groq Vision API to enable AI-powered image renaming.', 'ai-image-renamer') }}</p>
						</div>
						<div class="air-card-body">
							{% include 'admin/fields/api-key.twig' with {option_name: option_name, display_key: display_key, placeholder: placeholder, saved: saved} %}
						</div>
					</div>
				</div>

				{# Models Panel #}
				<div id="air-panel-models" class="air-panel" role="tabpanel" aria-labelledby="air-tab-models" hidden>
					<div class="air-card">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-grid-view"></span>
								{{ __('AI Models', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Choose the vision model used for analyzing images.', 'ai-image-renamer') }}</p>
						</div>
						<div class="air-card-body">
							<div class="air-setting-row air-setting-row--stacked">
								<div class="air-setting-control">
									<div class="air-model-cards">
										{% include 'admin/fields/model.twig' with {
											models: models,
											current: current,
											option_name: option_name,
											asset_url: asset_url
										} %}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				{# General Settings Panel #}
				<div id="air-panel-general" class="air-panel" role="tabpanel" aria-labelledby="air-tab-general" hidden>
					<div class="air-card">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-admin-settings"></span>
								{{ __('General Settings', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Configure basic plugin behavior.', 'ai-image-renamer') }}</p>
						</div>
						<div class="air-card-body">
							<div class="air-setting-row">
								<div class="air-setting-label">
									<label for="air_enabled">{{ __('Enable Auto-Rename', 'ai-image-renamer') }}</label>
									<p class="air-setting-description">{{ __('Automatically rename images when uploaded to the Media Library.', 'ai-image-renamer') }}</p>
								</div>
								<div class="air-setting-control">
									<label class="air-toggle">
										<input type="checkbox" id="air_enabled" name="{{ option_name }}[enabled]" value="1" {{ enabled ? 'checked' : '' }}>
										<span class="air-toggle-slider"></span>
									</label>
								</div>
							</div>
							<div class="air-setting-row">
								<div class="air-setting-label">
									<label for="air_set_alt_text">{{ __('Populate Alt Text', 'ai-image-renamer') }}</label>
									<p class="air-setting-description">{{ __('Use the generated description as the image alt attribute for accessibility.', 'ai-image-renamer') }}</p>
								</div>
								<div class="air-setting-control">
									<label class="air-toggle">
										<input type="checkbox" id="air_set_alt_text" name="{{ option_name }}[set_alt_text]" value="1" {{ set_alt_text ? 'checked' : '' }}>
										<span class="air-toggle-slider"></span>
									</label>
								</div>
							</div>
						</div>
					</div>
				</div>

				{# File Types Panel #}
				<div id="air-panel-filetypes" class="air-panel" role="tabpanel" aria-labelledby="air-tab-filetypes" hidden>
					<div class="air-card">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-format-image"></span>
								{{ __('File Types', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Select which image formats to process.', 'ai-image-renamer') }}</p>
						</div>
						<div class="air-card-body">
							<div class="air-filetypes-grid">
								{% for mime, label in available_types %}
									<label class="air-filetype-card {{ mime in file_types ? 'selected' : '' }}">
										<input type="checkbox" name="{{ option_name }}[file_types][]" value="{{ mime }}" {{ mime in file_types ? 'checked' : '' }}>
										<span class="air-filetype-icon">
											{% if mime == 'image/jpeg' %}
												<span class="dashicons dashicons-format-image"></span>
											{% elseif mime == 'image/png' %}
												<span class="dashicons dashicons-format-image"></span>
											{% elseif mime == 'image/webp' %}
												<span class="dashicons dashicons-format-image"></span>
											{% elseif mime == 'image/gif' %}
												<span class="dashicons dashicons-images-alt"></span>
											{% endif %}
										</span>
										<span class="air-filetype-label">{{ label }}</span>
									</label>
								{% endfor %}
							</div>
						</div>
					</div>
				</div>

				{# Advanced Settings Panel #}
				<div id="air-panel-advanced" class="air-panel" role="tabpanel" aria-labelledby="air-tab-advanced" hidden>
					<div class="air-card">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-admin-tools"></span>
								{{ __('Advanced Settings', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Fine-tune output generation.', 'ai-image-renamer') }}</p>
						</div>
						<div
							class="air-card-body">
							{# Max Keywords Setting #}
							<div class="air-setting-row">
								<div class="air-setting-label">
									<label for="air_max_keywords">{{ __('Max Keywords', 'ai-image-renamer') }}</label>
									<p class="air-setting-description">{{ __('Maximum number of keywords to include in the filename (1-10).', 'ai-image-renamer') }}</p>
								</div>
								<div class="air-setting-control">
									<input type="number" id="air_max_keywords" name="{{ option_name }}[max_keywords]" value="{{ max_keywords }}" min="1" max="10" class="small-text">
								</div>
							</div>
						</div>
					</div>

					{# Diagnostics Card #}
					<div class="air-card" style="margin-top: 20px;">
						<div class="air-card-header">
							<h2>
								<span class="dashicons dashicons-info"></span>
								{{ __('System Diagnostics', 'ai-image-renamer') }}
							</h2>
							<p class="air-card-description">{{ __('Server information for troubleshooting support issues.', 'ai-image-renamer') }}</p>
						</div>
						<div class="air-card-body">
							<table class="widefat air-diagnostics-table" style="border:none; box-shadow:none;">
								<tbody>
									<tr>
										<td>
											<strong>{{ __('PHP Version', 'ai-image-renamer') }}</strong>
										</td>
										<td>{{ diagnostics.php_version }}</td>
									</tr>
									<tr>
										<td>
											<strong>{{ __('WordPress Version', 'ai-image-renamer') }}</strong>
										</td>
										<td>{{ diagnostics.wp_version }}</td>
									</tr>
									<tr>
										<td>
											<strong>{{ __('Memory Limit', 'ai-image-renamer') }}</strong>
										</td>
										<td>{{ diagnostics.memory_limit }}</td>
									</tr>
									<tr>
										<td>
											<strong>{{ __('Max Upload Size', 'ai-image-renamer') }}</strong>
										</td>
										<td>{{ diagnostics.upload_max_size }}</td>
									</tr>
									<tr>
										<td>
											<strong>{{ __('cURL Enabled', 'ai-image-renamer') }}</strong>
										</td>
										<td>
											{% if diagnostics.curl_enabled %}
												<span class="dashicons dashicons-yes" style="color: #46b450;"></span>
												{{ __('Yes', 'ai-image-renamer') }}
											{% else %}
												<span class="dashicons dashicons-no" style="color: #dc3232;"></span>
												{{ __('No', 'ai-image-renamer') }}
											{% endif %}
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>

				{# Submit Button #}
				<div class="air-submit-row">
					<button type="submit" name="submit" id="submit" class="button button-primary air-button-with-icon">
						<span class="dashicons dashicons-saved"></span>
						{{ __('Save Settings', 'ai-image-renamer') }}
					</button>
				</div>
			</form>
		</main>

		{# Sidebar #}
		<aside class="air-settings-sidebar">
			{% include 'admin/sidebar.twig' %}
		</aside>
	</div>
</div>
